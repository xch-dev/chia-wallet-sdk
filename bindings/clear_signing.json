{
  "VaultSpendReveal": {
    "type": "class",
    "new": true,
    "fields": {
      "launcher_id": "Bytes32",
      "custody_hash": "TreeHash",
      "delegated_spend": "Spend"
    }
  },
  "VaultTransaction": {
    "type": "class",
    "new": true,
    "remote": true,
    "fields": {
      "new_custody_hash": "Option<TreeHash>",
      "payments": "Vec<ParsedPayment>",
      "nfts": "Vec<ParsedNftTransfer>",
      "drop_coins": "Vec<DropCoin>",
      "fee_paid": "u64",
      "total_fee": "u64",
      "reserved_fee": "u64",
      "p2_puzzle_hash": "Bytes32",
      "delegated_puzzle_hash": "Bytes32"
    }
  },
  "ParsedPayment": {
    "type": "class",
    "new": true,
    "remote": true,
    "fields": {
      "transfer_type": "TransferType",
      "asset_id": "Option<Bytes32>",
      "hidden_puzzle_hash": "Option<Bytes32>",
      "p2_puzzle_hash": "Bytes32",
      "coin": "Coin",
      "clawback": "Option<ClawbackV2>",
      "memos": "Vec<String>"
    }
  },
  "ParsedNftTransfer": {
    "type": "class",
    "new": true,
    "remote": true,
    "fields": {
      "transfer_type": "TransferType",
      "launcher_id": "Bytes32",
      "p2_puzzle_hash": "Bytes32",
      "coin": "Coin",
      "clawback": "Option<ClawbackV2>",
      "memos": "Vec<String>",
      "old_state": "NftState",
      "new_state": "NftState",
      "royalty_puzzle_hash": "Bytes32",
      "royalty_basis_points": "u16",
      "includes_unverifiable_updates": "bool"
    }
  },
  "NftState": {
    "type": "class",
    "new": true,
    "remote": true,
    "fields": {
      "parsed_metadata": "Option<NftMetadata>",
      "metadata_updater_puzzle_hash": "Bytes32",
      "owner": "Option<Bytes32>"
    }
  },
  "TransferType": {
    "type": "enum",
    "values": ["Sent", "Burned", "Offered", "Received", "Updated"]
  },
  "DropCoin": {
    "type": "class",
    "new": true,
    "remote": true,
    "fields": {
      "puzzle_hash": "Bytes32",
      "amount": "u64"
    }
  },
  "calculate_vault_puzzle_message": {
    "type": "function",
    "args": {
      "delegated_puzzle_hash": "Bytes32",
      "vault_puzzle_hash": "Bytes32"
    },
    "return": "Bytes"
  },
  "calculate_vault_coin_message": {
    "type": "function",
    "args": {
      "delegated_puzzle_hash": "Bytes32",
      "vault_coin_id": "Bytes32",
      "genesis_challenge": "Bytes32"
    },
    "return": "Bytes"
  },
  "calculate_vault_start_recovery_message": {
    "type": "function",
    "args": {
      "delegated_puzzle_hash": "Bytes32",
      "left_side_subtree_hash": "Bytes32",
      "recovery_timelock": "u64",
      "vault_coin_id": "Bytes32",
      "genesis_challenge": "Bytes32"
    },
    "return": "Bytes"
  }
}
